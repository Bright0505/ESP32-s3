#ifndef CONFIG_H
#define CONFIG_H

// Fallback values — used only when NVS is empty (first boot, no BLE provisioning yet)
// 首次使用請填入預設值，之後可透過 BLE 更新，不需重新燒錄
#define DEFAULT_SSID     "YOUR_WIFI_SSID"
#define DEFAULT_PASSWORD "YOUR_WIFI_PASSWORD"
#define DEFAULT_API_KEY  "YOUR_GEMINI_API_KEY"
#define DEFAULT_MODEL    "gemini-3-flash-preview"   // 可替換為其他 Gemini 模型

#endif
